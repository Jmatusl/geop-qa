  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  requirements     ActRequirement[]
  defaultArea      MntArea?         @relation(fields: [defaultAreaId], references: [id])
  defaultApplicant User?            @relation("ActMaster_DefaultApplicant", fields: [defaultApplicantUserId], references: [id])

  @@map("act_master_activity_names")
}

model ActActivity {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requirementId     String                  @map("requirement_id") @db.Uuid
  name              String                  @db.VarChar(200)
  activityTypeId    String?                 @map("activity_type_id") @db.Uuid
  description       String?
  location          String?                 @db.VarChar(200)
  locationId        String?                 @map("location_id") @db.Uuid
  startDate         DateTime?               @map("start_date") @db.Date
  endDate           DateTime?               @map("end_date") @db.Date
  statusActivity    String                  @default("PENDIENTE") @map("status_activity") @db.VarChar(20)
  statusId          String?                 @map("status_id") @db.Uuid
  estimatedValue    Decimal?                @default(0) @map("estimated_value") @db.Decimal(15, 2)
  registeredTime    Int?                    @map("registered_time")
  responsibleUserId String?                 @map("responsible_user_id") @db.Uuid
  supplierId        String?                 @map("supplier_id") @db.Uuid
  observations      String?
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  checkedAt         DateTime?               @map("checked_at") @db.Timestamptz(6)
  checkedById       String?                 @map("checked_by") @db.Uuid
  isChecked         Boolean                 @default(false) @map("is_checked")
  userId            String?                 @db.Uuid
  activityType      ActActivityType?        @relation(fields: [activityTypeId], references: [id])
  checkedBy         User?                   @relation("ActAct_CheckedBy", fields: [checkedById], references: [id])
  requirement       ActRequirement          @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  responsible       User?                   @relation("ActAct_Responsible", fields: [responsibleUserId], references: [id])
  supplier          MntSupplier?            @relation(fields: [supplierId], references: [id])
  user              User?                   @relation(fields: [userId], references: [id])
  activityLocation  MntActivityLocation?    @relation(fields: [locationId], references: [id])
  status            ActStatusAct?           @relation(fields: [statusId], references: [id])
  receptions        ActActivityReception[]
  attachments       ActActivityAttachment[]

  @@index([requirementId])
  @@index([locationId])
  @@index([statusId])
  @@map("act_activities")
}

model ActStatusAct {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @unique @db.VarChar(50)
  code         String        @unique @db.VarChar(10)
  colorHex     String?       @map("color_hex") @db.VarChar(7)
  displayOrder Int           @default(0) @map("display_order")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  activities   ActActivity[]

  @@map("act_status_acts")
}

model ActComment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requirementId String         @map("requirement_id") @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  comment       String
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  requirement   ActRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])

  @@index([requirementId])
  @@map("act_comments")
}

model ActAttachment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requirementId String         @map("requirement_id") @db.Uuid
  storagePath   String         @map("storage_path")
  publicUrl     String         @map("public_url")
  fileName      String         @map("file_name") @db.VarChar(255)
  fileSize      Int?           @map("file_size")
  mimeType      String?        @map("mime_type") @db.VarChar(100)
  uploadedById  String         @map("uploaded_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  requirement   ActRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  uploadedBy    User           @relation(fields: [uploadedById], references: [id])

  @@index([requirementId])
  @@map("act_attachments")
}

model ActActivityAttachment {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId   String      @map("activity_id") @db.Uuid
  storagePath  String      @map("storage_path")
  publicUrl    String      @map("public_url")
  fileName     String      @map("file_name") @db.VarChar(255)
  fileSize     Int?        @map("file_size")
  mimeType     String?     @map("mime_type") @db.VarChar(100)
  uploadedById String      @map("uploaded_by") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  activity     ActActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])

  @@index([activityId])
  @@map("act_activity_attachments")
}

model ActActivityReception {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId   String                 @map("activity_id") @db.Uuid
  isAccepted   Boolean                @default(false) @map("is_accepted")
  comment      String?
  receivedById String                 @map("received_by_id") @db.Uuid
  receivedAt   DateTime               @default(now()) @map("received_at") @db.Timestamptz(6)
  activity     ActActivity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  receivedBy   User                   @relation("ActReception_ReceivedBy", fields: [receivedById], references: [id])
  evidences    ActReceptionEvidence[]

  @@index([activityId])
  @@index([receivedById])
  @@map("act_activity_receptions")
}

model ActReceptionEvidence {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receptionId String               @map("reception_id") @db.Uuid
  storagePath String               @map("storage_path")
  publicUrl   String               @map("public_url")
  fileSize    Int?                 @map("file_size")
  mimeType    String?              @map("mime_type") @db.VarChar(50)
  capturedAt  DateTime?            @map("captured_at") @db.Timestamptz(6)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  reception   ActActivityReception @relation(fields: [receptionId], references: [id], onDelete: Cascade)

  @@index([receptionId])
  @@map("act_reception_evidences")
}

model ActTimeline {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requirementId String         @map("requirement_id") @db.Uuid
  changedById   String         @map("changed_by") @db.Uuid
  action        String         @db.VarChar(50)
  prevStatusId  String?        @map("prev_status_id") @db.Uuid
  newStatusId   String?        @map("new_status_id") @db.Uuid
  comment       String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  changedBy     User           @relation(fields: [changedById], references: [id])
  newStatus     ActStatusReq?  @relation("ActTimeline_NewStatus", fields: [newStatusId], references: [id])
  prevStatus    ActStatusReq?  @relation("ActTimeline_PrevStatus", fields: [prevStatusId], references: [id])
  requirement   ActRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@map("act_timeline")
}

// ============================================
// SISTEMA CENTRALIZADO DE PERMISOS POR MÓDULO
// ============================================

model Module {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String   @unique @db.VarChar(50)
  name         String   @db.VarChar(100)
  description  String?
  icon         String?  @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  emailEnabled Boolean  @default(true) @map("email_enabled")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  permissions          ModulePermission[]
  userPermissions      UserModulePermission[]
  notificationSettings ModuleNotificationSetting[]
  approvalRules        ModuleApprovalRule[]

  @@index([code])
  @@index([isActive])
  @@map("modules")
}

model ModulePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId     String   @map("module_id") @db.Uuid
  code         String   @db.VarChar(50)
  name         String   @db.VarChar(100)
  description  String?
  category     String?  @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  module          Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userPermissions UserModulePermission[]

  @@unique([moduleId, code])
  @@index([moduleId])
  @@index([category])
  @@map("module_permissions")
}

model UserModulePermission {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  moduleId     String    @map("module_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  grantedBy    String?   @map("granted_by") @db.Uuid
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(6)

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  module        Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  permission    ModulePermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByUser User?            @relation("PermissionGrantedBy", fields: [grantedBy], references: [id])

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([moduleId])
  @@index([permissionId])
  @@index([expiresAt])
  @@map("user_module_permissions")
}

model ModuleNotificationSetting {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId            String   @map("module_id") @db.Uuid
  eventKey            String   @map("event_key") @db.VarChar(100)
  eventName           String   @map("event_name") @db.VarChar(200)
  description         String?
  isEnabled           Boolean  @default(true) @map("is_enabled")
  requiredPermissions String[] @map("required_permissions")
  template            String?  @db.VarChar(100)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, eventKey])
  @@index([moduleId])
  @@index([isEnabled])
  @@map("module_notification_settings")
}

model ModuleApprovalRule {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId      String   @map("module_id") @db.Uuid
  ruleKey       String   @map("rule_key") @db.VarChar(100)
  ruleName      String   @map("rule_name") @db.VarChar(200)
  description   String?
  isEnabled     Boolean  @default(false) @map("is_enabled")
  configuration Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy     String?  @map("updated_by") @db.Uuid

  module        Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  updatedByUser User?  @relation("ApprovalRuleUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([moduleId, ruleKey])
  @@index([moduleId])
  @@index([isEnabled])
  @@map("module_approval_rules")
}

model UserNotificationPreference {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  moduleCode String   @map("module_code") @db.VarChar(50)
  eventKey   String   @map("event_key") @db.VarChar(100)
  isOptedOut Boolean  @default(false) @map("is_opted_out")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleCode, eventKey])
  @@index([userId])
  @@map("user_notification_preferences")
}
