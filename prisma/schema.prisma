/// Bodega física
model BodegaWarehouse {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String               @unique @db.VarChar(30)
  name               String               @db.VarChar(120)
  description        String?
  location           String?
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  requests           BodegaTransaction[]
  lots               BodegaLot[]
  reservations       BodegaReservation[]
  serialNumbers      BodegaSerialNumber[]
  stocks             BodegaStock[]
  transactions       BodegaTransaction[]     @relation("BodegaTransaction_Warehouse")
  targetTransactions BodegaTransaction[]     @relation("BodegaTransaction_TargetWarehouse")
  transactionItems   BodegaTransactionItem[] @relation("BodegaTransactionItem_Warehouse")

  @@index([isActive])
  @@map("bodega_warehouses")
}

/// Maestro de artículos de bodega
model BodegaArticle {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String                  @unique @db.VarChar(50)
  name              String                  @db.VarChar(255)
  description       String?
  partNumber        String?                 @map("part_number") @db.VarChar(100)
  brand             String?                 @db.VarChar(100)
  model             String?                 @db.VarChar(100)
  internalCode      String?                 @map("internal_code") @db.VarChar(50)
  articleType       String?                 @map("article_type") @db.VarChar(50)
  quality           String?                 @db.VarChar(50)
  isCritical        Boolean                 @default(false) @map("is_critical")
  unit              String                  @default("UNI") @db.VarChar(20)
  minimumStock      Decimal                 @default(0) @map("minimum_stock") @db.Decimal(14, 3)
  isActive          Boolean                 @default(true) @map("is_active")
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  imagePath         String?                 @map("image_path") @db.VarChar(512)
  technicalFilePath String?                 @map("technical_file_path") @db.VarChar(512)
  lots              BodegaLot[]
  reservationItems  BodegaReservation[]
  serialNumbers     BodegaSerialNumber[]
  stocks            BodegaStock[]
  transactionItems  BodegaTransactionItem[]

  @@index([isActive])
  @@map("bodega_articles")
}

/// Existencia actual de artículo por bodega
model BodegaStock {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouseId       String          @map("warehouse_id") @db.Uuid
  articleId         String          @map("article_id") @db.Uuid
  quantity          Decimal         @default(0) @db.Decimal(14, 3)
  reservedQuantity  Decimal         @default(0) @map("reserved_quantity") @db.Decimal(14, 3)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  stockNoVerificado Decimal         @default(0) @map("stock_no_verificado") @db.Decimal(14, 3)
  stockVerificado   Decimal         @default(0) @map("stock_verificado") @db.Decimal(14, 3)
  article           BodegaArticle   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  warehouse         BodegaWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, articleId])
  @@index([articleId])
  @@map("bodega_stock")
}

/// Transacción de bodega unificada (Solicitud, Ingreso, Retiro, Transferencia, Ajuste)
model BodegaTransaction {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folio             String  @unique @db.VarChar(50)
  type              String  @db.VarChar(30) // INGRESO, RETIRO, AJUSTE, TRANSFERENCIA, SOLICITUD
  status            String  @default("PENDIENTE") @db.VarChar(30)
  warehouseId       String  @map("warehouse_id") @db.Uuid
  targetWarehouseId String? @map("target_warehouse_id") @db.Uuid

  // Datos de Solicitud / Retiro
  title        String?   @db.VarChar(255)
  description  String?
  priority     String    @default("NORMAL") @db.VarChar(20)
  requiredDate DateTime? @map("required_date") @db.Date
  requestedBy  String?   @map("requested_by") @db.Uuid
  responsable  String?   @db.VarChar(150) // Quien recibe o entrega físicamente

  // Datos Generales / Auditoría
  reason            String?
  observations      String?
  externalReference String? @map("external_reference") @db.VarChar(100)
  quotationNumber   String? @map("quotation_number") @db.VarChar(100)
  deliveryGuide     String? @map("delivery_guide") @db.VarChar(100)
  metadata          Json?

  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  approvedBy String?   @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at") @db.Timestamptz(6)

  appliedBy String?   @map("applied_by") @db.Uuid
  appliedAt DateTime? @map("applied_at") @db.Timestamptz(6)

  // Relaciones
  items        BodegaTransactionItem[]
  logs         BodegaTransactionLog[]
  evidences    BodegaTransactionEvidence[]
  reservations BodegaReservation[]

  creator           User             @relation("BodegaTransaction_CreatedBy", fields: [createdBy], references: [id])
  requester         User?            @relation("BodegaTransaction_RequestedBy", fields: [requestedBy], references: [id])
  approver          User?            @relation("BodegaTransaction_ApprovedBy", fields: [approvedBy], references: [id])
  applier           User?            @relation("BodegaTransaction_AppliedBy", fields: [appliedBy], references: [id])
  warehouse         BodegaWarehouse  @relation("BodegaTransaction_Warehouse", fields: [warehouseId], references: [id])
  targetWarehouse   BodegaWarehouse? @relation("BodegaTransaction_TargetWarehouse", fields: [targetWarehouseId], references: [id])
  bodegaWarehouse   BodegaWarehouse? @relation(fields: [bodegaWarehouseId], references: [id])
  bodegaWarehouseId String?          @db.Uuid

  @@index([type])
  @@index([status])
  @@index([warehouseId])
  @@index([requestedBy])
  @@index([createdBy])
  @@index([createdAt])
  @@map("bodega_transactions")
}

/// Item de transacción de bodega
model BodegaTransactionItem {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String  @map("transaction_id") @db.Uuid
  articleId     String  @map("article_id") @db.Uuid
  quantity      Decimal @db.Decimal(14, 3)

  // Específicos de Retiro / Solicitud
  deliveredQuantity Decimal @default(0) @map("delivered_quantity") @db.Decimal(14, 3)

  // Específicos de Ingreso / Valorización
  unitCost       Decimal? @map("unit_cost") @db.Decimal(14, 2)
  initialBalance Decimal? @map("initial_balance") @db.Decimal(14, 3)
  currentBalance Decimal? @map("current_balance") @db.Decimal(14, 3)

  // Verificación / Control
  cantidadVerificada Decimal?  @map("cantidad_verificada") @db.Decimal(14, 3)
  fechaVerificacion  DateTime? @map("fecha_verificacion") @db.Timestamptz(6)
  verificadoPorId    String?   @map("verificado_por_id") @db.Uuid

  observations            String?
  sourceTransactionItemId String?  @map("source_transaction_item_id") @db.Uuid
  warehouseId             String?  @map("warehouse_id") @db.Uuid
  displayOrder            Int      @default(0) @map("display_order")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  article       BodegaArticle               @relation(fields: [articleId], references: [id])
  transaction   BodegaTransaction           @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  warehouse     BodegaWarehouse?            @relation("BodegaTransactionItem_Warehouse", fields: [warehouseId], references: [id])
  generatedLots BodegaLot[]                 @relation("BodegaLot_GeneratedFromItem")
  serialNumbers BodegaSerialNumber[]        @relation("BodegaSerialNumber_SourceItem")
  evidences     BodegaTransactionEvidence[]
  reservations  BodegaReservation[]

  @@index([transactionId])
  @@index([articleId])
  @@index([warehouseId])
  @@map("bodega_transaction_items")
}

/// Bitácora de transacción de bodega
model BodegaTransactionLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  action        String   @db.VarChar(100)
  description   String
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy     String?  @map("created_by") @db.Uuid

  creator     User?             @relation("BodegaTransactionLog_CreatedBy", fields: [createdBy], references: [id])
  transaction BodegaTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([createdAt])
  @@map("bodega_transaction_logs")
}

/// Evidencia de transacción de bodega
model BodegaTransactionEvidence {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId     String   @map("transaction_id") @db.Uuid
  transactionItemId String?  @map("transaction_item_id") @db.Uuid
  url               String
  key               String?
  fileName          String?  @map("file_name")
  fileSize          Int?     @map("file_size")
  fileType          String?  @map("file_type")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  transaction     BodegaTransaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionItem BodegaTransactionItem? @relation(fields: [transactionItemId], references: [id])

  @@index([transactionId])
  @@index([transactionItemId])
  @@map("bodega_transaction_evidences")
}

/// Lote de inventario de bodega
model BodegaLot {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String                 @unique @db.VarChar(80)
  warehouseId           String                 @map("warehouse_id") @db.Uuid
  articleId             String                 @map("article_id") @db.Uuid
  sourceMovementItemId  String?                @map("source_movement_item_id") @db.Uuid
  initialQuantity       Decimal                @map("initial_quantity") @db.Decimal(14, 3)
  currentQuantity       Decimal                @default(0) @map("current_quantity") @db.Decimal(14, 3)
  unitCost              Decimal?               @map("unit_cost") @db.Decimal(14, 2)
  manufactureDate       DateTime?              @map("manufacture_date") @db.Date
  expirationDate        DateTime?              @map("expiration_date") @db.Date
  provider              String?                @db.VarChar(255)
  invoiceNumber         String?                @map("invoice_number") @db.VarChar(100)
  status                String                 @default("ACTIVO") @db.VarChar(30)
  observations          String?
  createdBy             String                 @map("created_by") @db.Uuid
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  article               BodegaArticle          @relation(fields: [articleId], references: [id])
  creator               User                   @relation("BodegaLot_CreatedBy", fields: [createdBy], references: [id])
  sourceTransactionItem BodegaTransactionItem? @relation("BodegaLot_GeneratedFromItem", fields: [sourceMovementItemId], references: [id])
  warehouse             BodegaWarehouse        @relation(fields: [warehouseId], references: [id])
  serialNumbers         BodegaSerialNumber[]

  @@index([warehouseId])
  @@index([articleId])
  @@index([status])
  @@index([expirationDate])
  @@index([createdAt])
  @@map("bodega_lots")
}

/// Número de serie de inventario de bodega
model BodegaSerialNumber {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lotId                 String                 @map("lot_id") @db.Uuid
  warehouseId           String                 @map("warehouse_id") @db.Uuid
  articleId             String                 @map("article_id") @db.Uuid
  sourceMovementItemId  String?                @map("source_movement_item_id") @db.Uuid
  serialNumber          String                 @unique @map("serial_number") @db.VarChar(120)
  status                String                 @default("DISPONIBLE") @db.VarChar(30)
  notes                 String?
  createdBy             String                 @map("created_by") @db.Uuid
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  article               BodegaArticle          @relation(fields: [articleId], references: [id])
  creator               User                   @relation("BodegaSerialNumber_CreatedBy", fields: [createdBy], references: [id])
  lot                   BodegaLot              @relation(fields: [lotId], references: [id], onDelete: Cascade)
  sourceTransactionItem BodegaTransactionItem? @relation("BodegaSerialNumber_SourceItem", fields: [sourceMovementItemId], references: [id])
  warehouse             BodegaWarehouse        @relation(fields: [warehouseId], references: [id])
  user                  User?                  @relation(fields: [userId], references: [id])
  userId                String?                @db.Uuid

  @@index([lotId])
  @@index([warehouseId])
  @@index([articleId])
  @@index([status])
  @@index([createdAt])
  @@map("bodega_serial_numbers")
}

/// Reserva de stock para solicitud
model BodegaReservation {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId     String                @map("transaction_id") @db.Uuid
  transactionItemId String                @map("transaction_item_id") @db.Uuid
  warehouseId       String                @map("warehouse_id") @db.Uuid
  articleId         String                @map("article_id") @db.Uuid
  quantity          Decimal               @db.Decimal(14, 3)
  status            String                @default("ACTIVA") @db.VarChar(20)
  expiresAt         DateTime?             @map("expires_at") @db.Timestamptz(6)
  createdBy         String                @map("created_by") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  releasedAt        DateTime?             @map("released_at") @db.Timestamptz(6)
  article           BodegaArticle         @relation(fields: [articleId], references: [id])
  creator           User                  @relation("BodegaReservation_CreatedBy", fields: [createdBy], references: [id])
  transaction       BodegaTransaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade, map: "bodega_reservations_transaction_fkey")
  transactionItem   BodegaTransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade, map: "bodega_item_reservation_fkey")
  warehouse         BodegaWarehouse       @relation(fields: [warehouseId], references: [id])

  @@index([transactionId])
  @@index([transactionItemId])
  @@index([warehouseId])
  @@index([articleId])
  @@index([status])
  @@map("bodega_reservations")
}

/// Centro de Costo (Añadido)
model BodegaCostCenter {
