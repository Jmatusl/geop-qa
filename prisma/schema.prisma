// --- Operación ---

model MntRequest {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folio          Int     @unique @default(autoincrement())
  folioPrefix    String  @default("RD") @map("folio_prefix") @db.VarChar(10)
  installationId String  @map("installation_id") @db.Uuid
  equipmentId    String  @map("equipment_id") @db.Uuid
  typeId         String  @map("type_id") @db.Uuid
  statusId       String  @map("status_id") @db.Uuid
  applicantId    String? @map("applicant_id") @db.Uuid
  description    String  @db.Text

  // Tercerización
  tercerizedReason String? @map("tercerized_reason") @db.Text // Justificación obligatoria al cambiar estado a Tercerizar

  // Aprobación
  isApproved   Boolean   @default(false) @map("is_approved")
  approvedAt   DateTime? @map("approved_at") @db.Timestamptz(6)
  approvedById String?   @map("approved_by") @db.Uuid

  // Fechas y Estimaciones
  estimatedEndDate DateTime? @map("estimated_end_date") @db.Date
  actualEndDate    DateTime? @map("actual_end_date") @db.Date

  // Auditoría
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  installation MntInstallation  @relation(fields: [installationId], references: [id])
  equipment    MntEquipment     @relation(fields: [equipmentId], references: [id])
  type         MntRequestType   @relation(fields: [typeId], references: [id])
  status       MntRequestStatus @relation(fields: [statusId], references: [id])
  applicant    MntApplicant?    @relation(fields: [applicantId], references: [id])
  createdBy    User             @relation("RequestCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?            @relation("RequestApprovedBy", fields: [approvedById], references: [id])

  evidences                   MntRequestEvidence[]
  timeline                    MntRequestTimeline[]
  iterations                  MntRequestIteration[]
  expenses                    MntRequestExpense[]
  mntWorkRequirementRelations MntWorkRequirementRelation[]

  @@index([installationId])
  @@index([equipmentId])
  @@index([statusId])
  @@map("mnt_requests")
}

model MntRequestEvidence {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId   String    @map("request_id") @db.Uuid
  storagePath String    @map("storage_path")
  publicUrl   String    @map("public_url")
  fileSize    Int?      @map("file_size")
  mimeType    String?   @map("mime_type") @db.VarChar(50)
  capturedAt  DateTime? @map("captured_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  request MntRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("mnt_request_evidences")
}

model MntRequestTimeline {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId    String            @map("request_id") @db.Uuid
  changedById  String            @map("changed_by") @db.Uuid
  action       String            @db.VarChar(50)
  prevStatusId String?           @map("prev_status_id") @db.Uuid
  newStatusId  String?           @map("new_status_id") @db.Uuid
  comment      String?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  changedBy    User              @relation(fields: [changedById], references: [id])
  request      MntRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  prevStatus   MntRequestStatus? @relation("PrevStatus", fields: [prevStatusId], references: [id])
  newStatus    MntRequestStatus? @relation("NewStatus", fields: [newStatusId], references: [id])

  @@index([requestId])
  @@map("mnt_request_timeline")
}

model MntUserNotificationPreference {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailEnabled Boolean @default(true) @map("email_enabled")
  onNewRequest Boolean @default(true) @map("on_new_request")
  onApproval   Boolean @default(true) @map("on_approval")
  onReprogram  Boolean @default(true) @map("on_reprogram")
  onClose      Boolean @default(true) @map("on_close")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("mnt_user_notification_preferences")
}

model MntRequestIteration {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId      String   @map("request_id") @db.Uuid
  description    String   @db.Text
  technicianName String?  @map("technician_name")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById    String   @map("created_by") @db.Uuid

  request   MntRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdBy User       @relation(fields: [createdById], references: [id])

  @@map("mnt_request_iterations")
}

model MntRequestExpense {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId   String   @map("request_id") @db.Uuid
  description String   @db.VarChar(200)
  amount      Int // Valor en CLP, sin decimales
  type        String   @db.VarChar(20) // SPARE_PART, LABOR, EXTERNAL, OTHER
  quantity    Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  request MntRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("mnt_request_expenses")
}

model MntWorkRequirement {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folio       String  @unique // [PREFIJO]-[SECUENCIAL]
  title       String  @db.VarChar(200)
  description String? @db.Text
  providerId  String  @map("provider_id") @db.Uuid
  statusId    String  @map("status_id") @db.Uuid

  // Administrativo / Financiero
  ocNumber          String? @map("oc_number") @db.VarChar(50)
  ocValue           Float?  @map("oc_value")
  invoiceNumber     String? @map("invoice_number") @db.VarChar(50)
  invoiceValue      Float?  @map("invoice_value")
  requisitionNumber String? @map("requisition_number") @db.VarChar(50)

  // Auditoría
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  provider  MntSupplier                  @relation(fields: [providerId], references: [id])
  status    MntWorkRequirementStatus     @relation(fields: [statusId], references: [id])
  createdBy User                         @relation("WR_CreatedBy", fields: [createdById], references: [id])
  requests  MntWorkRequirementRelation[]
  evidences MntWorkRequirementEvidence[]

  @@map("mnt_work_requirements")
}

model MntWorkRequirementStatus {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique @db.VarChar(50)
  description  String?  @db.Text
  colorHex     String?  @map("color_hex") @db.VarChar(7)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  requirements MntWorkRequirement[]

  @@map("mnt_work_requirement_statuses")
}

model MntWorkRequirementRelation {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workRequirementId String @map("work_requirement_id") @db.Uuid
  requestId         String @map("request_id") @db.Uuid

  workRequirement MntWorkRequirement @relation(fields: [workRequirementId], references: [id], onDelete: Cascade)
  request         MntRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([workRequirementId, requestId])
  @@map("mnt_work_requirement_relations")
}

model MntWorkRequirementEvidence {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workRequirementId String    @map("work_requirement_id") @db.Uuid
  storagePath       String    @map("storage_path")
  publicUrl         String    @map("public_url")
  fileSize          Int?      @map("file_size")
  mimeType          String?   @map("mime_type") @db.VarChar(50)
  capturedAt        DateTime? @map("captured_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workRequirement MntWorkRequirement @relation(fields: [workRequirementId], references: [id], onDelete: Cascade)

  @@index([workRequirementId])
  @@map("mnt_work_requirement_evidences")
}

