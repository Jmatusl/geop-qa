generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String     @unique @db.VarChar(50)
  name        String     @db.VarChar(100)
  description String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  userRoles   UserRole[]

  @@map("roles")
}

model User {
  id                             String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                          String                         @unique @db.VarChar(255)
  emailVerifiedAt                DateTime?                      @map("email_verified_at") @db.Timestamptz(6)
  passwordHash                   String?                        @map("password_hash") @db.VarChar(255)
  firstName                      String                         @map("first_name") @db.VarChar(100)
  lastName                       String                         @map("last_name") @db.VarChar(100)
  middleName                     String?                        @map("middle_name") @db.VarChar(100)
  rut                            String?                        @unique @db.VarChar(12)
  phone                          String?                        @db.VarChar(20)
  experienceYears                Int?                           @map("experience_years")
  avatarUrl                      String?                        @map("avatar_url")
  avatarFile                     String?
  mustChangePassword             Boolean                        @default(false) @map("must_change_password")
  isActive                       Boolean                        @default(true) @map("is_active")
  isDeactivated                  Boolean                        @default(false) @map("is_deactivated")
  deactivationReasonId           String?                        @map("deactivation_reason_id") @db.Uuid
  deactivationComment            String?                        @map("deactivation_comment")
  deactivatedAt                  DateTime?                      @map("deactivated_at") @db.Timestamptz(6)
  deactivatedById                String?                        @map("deactivated_by") @db.Uuid
  lastLoginAt                    DateTime?                      @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp                    String?                        @map("last_login_ip")
  failedLoginAttempts            Int                            @default(0) @map("failed_login_attempts")
  lockedUntil                    DateTime?                      @map("locked_until") @db.Timestamptz(6)
  createdAt                      DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById                    String?                        @map("created_by") @db.Uuid
  updatedById                    String?                        @map("updated_by") @db.Uuid
  personId                       String?                        @unique @map("person_id") @db.Uuid
  accessLogs                     AccessLog[]
  actActivitiesChecked           ActActivity[]                  @relation("ActAct_CheckedBy")
  actActivitiesAsResponsible     ActActivity[]                  @relation("ActAct_Responsible")
  actActivities                  ActActivity[]
  actAttachmentsUploaded         ActAttachment[]
  actActivityAttachmentsUploaded ActActivityAttachment[]
  actComments                    ActComment[]
  actRequirementsAsApplicant     ActRequirement[]               @relation("ActReq_Applicant")
  actRequirementsCreated         ActRequirement[]               @relation("ActReq_CreatedBy")
  actRequirementsAsResponsible   ActRequirement[]               @relation("ActReq_Responsible")
  actRequirementsApproved        ActRequirement[]               @relation("ActReq_ApprovedBy")
  actRequirementsChecked         ActRequirement[]               @relation("ActReq_CheckedBy")
  actEmailsSent                  ActEmailSent[]                 @relation("ActEmailSent_SentBy")
  actReceptions                  ActActivityReception[]         @relation("ActReception_ReceivedBy")
  actTimelineEntries             ActTimeline[]
  activationTokens               ActivationToken[]
  settingsUpdates                AppSetting[]
  settingsAuditChanges           AppSettingAudit[]
  emailTemplates                 EmailTemplate[]
  menuAuditChanges               MenuAudit[]
  mntApplicants                  MntApplicant?
  mntRequestIterations           MntRequestIteration[]
  mntRequestTimelines            MntRequestTimeline[]
  mntRequestsApproved            MntRequest[]                   @relation("RequestApprovedBy")
  mntRequestsCreated             MntRequest[]                   @relation("RequestCreatedBy")
  mntTechnicalResponsibles       MntTechnicalResponsible?
  mntNotificationPreference      MntUserNotificationPreference?
  mntWorkRequirements            MntWorkRequirement[]           @relation("WR_CreatedBy")
  passwordResetTokens            PasswordResetToken[]
  sessions                       Session[]
  signatures                     Signature[]
  userIdentities                 UserIdentity[]
  userRoles                      UserRole[]
  modulePermissions              UserModulePermission[]
  permissionsGranted             UserModulePermission[]         @relation("PermissionGrantedBy")
  approvalRulesUpdated           ModuleApprovalRule[]           @relation("ApprovalRuleUpdatedBy")
  createdBy                      User?                          @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers                   User[]                         @relation("UserCreatedBy")
  deactivatedBy                  User?                          @relation("UserDeactivatedBy", fields: [deactivatedById], references: [id])
  deactivatedUsers               User[]                         @relation("UserDeactivatedBy")
  deactivationReason             UserDeactivationReason?        @relation(fields: [deactivationReasonId], references: [id])
  person                         Person?                        @relation(fields: [personId], references: [id])
  updatedBy                      User?                          @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  updatedUsers                   User[]                         @relation("UserUpdatedBy")
  actMasterDefaultApplicant      ActMasterActivityName[]        @relation("ActMaster_DefaultApplicant")
  notificationPreferences        UserNotificationPreference[]   @relation("UserNotificationPreferences")

  @@index([email])
  @@index([rut])
  @@index([isActive])
  @@index([isDeactivated])
  @@index([personId])
  @@map("users")
}

model UserRole {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?  @map("assigned_by") @db.Uuid
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model UserIdentity {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String    @db.VarChar(50)
  providerSubject String    @map("provider_subject") @db.VarChar(255)
  providerEmail   String    @map("provider_email") @db.VarChar(255)
  isEnabled       Boolean   @default(true) @map("is_enabled")
  linkedAt        DateTime  @default(now()) @map("linked_at") @db.Timestamptz(6)
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamptz(6)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([providerEmail])
  @@map("user_identities")
}

model Session {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  token          String   @unique @db.VarChar(255)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  lastActivityAt DateTime @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model ActivationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("activation_tokens")
}

model MenuItem {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String     @unique @db.VarChar(100)
  title     String     @db.VarChar(100)
  icon      String?    @db.VarChar(50)
  path      String?    @db.VarChar(255)
  enabled   Boolean    @default(true)
  order     Int        @default(0)
  showIcon  Boolean    @default(true) @map("show_icon")
  parentId  String?    @map("parent_id") @db.Uuid
  roles     String[]   @db.VarChar(50)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent    MenuItem?  @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuItemChildren")

  @@index([key])
  @@index([parentId])
  @@index([enabled])
  @@index([order])
  @@map("menu_items")
}

model MenuAudit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  previousJson Json     @map("previous_json")
  newJson      Json     @map("new_json")
  changedById  String   @map("changed_by") @db.Uuid
  changeReason String?  @map("change_reason")
  changedAt    DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedBy    User     @relation(fields: [changedById], references: [id])

  @@index([changedAt(sort: Desc)])
  @@map("menu_audit")
}

model AccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  eventType  String   @map("event_type") @db.VarChar(50)
  module     String?  @db.VarChar(50)
  pageUrl    String?  @map("page_url")
  endpoint   String?
  httpMethod String?  @map("http_method") @db.VarChar(10)
  statusCode Int?     @map("status_code")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
  @@map("access_logs")
}

model UserDeactivationReason {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String   @unique @db.VarChar(50)
  name         String   @db.VarChar(100)
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  users        User[]

  @@map("user_deactivation_reasons")
}

model AppSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  hasCustomUi Boolean  @default(false) @map("has_custom_ui")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedById String?  @map("updated_by") @db.Uuid
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@index([key])
  @@map("app_settings")
}

model AppSettingAudit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settingKey   String   @map("setting_key") @db.VarChar(100)
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  changedById  String?  @map("changed_by") @db.Uuid
  changeReason String?  @map("change_reason")
  changedAt    DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedBy    User?    @relation(fields: [changedById], references: [id])

  @@index([settingKey])
  @@index([changedAt(sort: Desc)])
  @@map("app_settings_audit")
}

model WorkGroup {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String            @unique @db.VarChar(50)
  name      String            @db.VarChar(100)
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  persons   PersonWorkGroup[]

  @@map("work_groups")
}

model Area {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String       @unique @db.VarChar(50)
  name      String       @db.VarChar(100)
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  persons   PersonArea[]

  @@map("areas")
}

model JobPosition {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String              @unique @db.VarChar(50)
  name      String              @db.VarChar(100)
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  persons   PersonJobPosition[]

  @@map("job_positions")
}

model Person {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rut                   String              @unique @db.VarChar(12)
  firstName             String              @map("first_name") @db.VarChar(100)
  lastName              String              @map("last_name") @db.VarChar(100)
  motherLastName        String?             @map("mother_last_name") @db.VarChar(100)
  email                 String?             @db.VarChar(255)
  phone                 String?             @db.VarChar(20)
  address               String?             @db.VarChar(255)
  imagePath             String?             @map("image_path") @db.VarChar(255)
  nationality           String?             @db.VarChar(50)
  birthDate             DateTime?           @map("birth_date") @db.Date
  civilStatus           String?             @map("civil_status") @db.VarChar(20)
  shoeSize              String?             @map("shoe_size") @db.VarChar(10)
  shirtSize             String?             @map("shirt_size") @db.VarChar(10)
  pantsSize             String?             @map("pants_size") @db.VarChar(10)
  emergencyContactName  String?             @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone String?             @map("emergency_contact_phone") @db.VarChar(20)
  bankName              String?             @map("bank_name") @db.VarChar(50)
  accountType           String?             @map("account_type") @db.VarChar(20)
  accountNumber         String?             @map("account_number") @db.VarChar(50)
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  areas                 PersonArea[]
  jobPositions          PersonJobPosition[]
  supervisors           PersonSupervisor[]
  subordinates          PersonSupervisor[]  @relation("PersonSubordinates")
  workGroups            PersonWorkGroup[]
  user                  User?

  @@map("persons")
}

model PersonWorkGroup {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId    String    @map("person_id") @db.Uuid
  workGroupId String    @map("work_group_id") @db.Uuid
  assignedAt  DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy  String?   @map("assigned_by") @db.Uuid
  person      Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  workGroup   WorkGroup @relation(fields: [workGroupId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([workGroupId])
  @@map("person_work_groups")
}

model PersonArea {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId   String   @map("person_id") @db.Uuid
  areaId     String   @map("area_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?  @map("assigned_by") @db.Uuid
  area       Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([areaId])
  @@map("person_areas")
}

model PersonJobPosition {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId      String      @map("person_id") @db.Uuid
  jobPositionId String      @map("job_position_id") @db.Uuid
  startDate     DateTime    @map("start_date") @db.Date
  endDate       DateTime?   @map("end_date") @db.Date
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy     String?     @map("created_by") @db.Uuid
  jobPosition   JobPosition @relation(fields: [jobPositionId], references: [id], onDelete: Cascade)
  person        Person      @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([jobPositionId])
  @@map("person_job_positions")
}

model PersonSupervisor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId     String   @map("person_id") @db.Uuid
  supervisorId String   @map("supervisor_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  isActive     Boolean  @default(true) @map("is_active")
  person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  supervisor   Person   @relation("PersonSubordinates", fields: [supervisorId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([supervisorId])
  @@map("person_supervisors")
}

model EmailTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  subject     String   @db.VarChar(255)
  htmlContent String   @map("html_content")
  description String?
  variables   Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedById String?  @map("updated_by") @db.Uuid
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@map("email_templates")
}

model MntFarmingCenter {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siepCode         String             @unique @map("siep_code") @db.VarChar(50)
  name             String             @db.VarChar(100)
  latitude         Float?
  longitude        Float?
  responsibleName  String?            @map("responsible_name") @db.VarChar(100)
  commune          String?            @db.VarChar(100)
  region           String?            @db.VarChar(100)
  productionAreaId String?            @map("production_area_id") @db.Uuid
  ownerCompany     String?            @map("owner_company") @db.VarChar(100)
  productionCycle  String?            @map("production_cycle") @db.VarChar(50)
  description      String?
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  productionArea   MntProductionArea? @relation(fields: [productionAreaId], references: [id])
  installations    MntInstallation[]

  @@map("mnt_farming_centers")
}

model MntProductionArea {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String             @unique @db.VarChar(100)
  description    String?
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  farmingCenters MntFarmingCenter[]

  @@map("mnt_production_areas")
}

model MntInstallation {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(100)
  folio            String?           @db.VarChar(50)
  internalCode     String?           @map("internal_code") @db.VarChar(50)
  installationType String?           @map("installation_type") @db.VarChar(50)
  latitude         Float?
  longitude        Float?
  farmingCenterId  String?           @map("farming_center_id") @db.Uuid
  description      String?
  observations     String?
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  equipments       MntEquipment[]
  farmingCenter    MntFarmingCenter? @relation(fields: [farmingCenterId], references: [id])
  requests         MntRequest[]
  applicants       MntApplicant[]    @relation("ApplicantInstallations")
  actRequirements  ActRequirement[]

  @@map("mnt_installations")
}

model MntArea {
  id                     String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String                    @db.VarChar(100)
  description            String?
  signatureId            String?                   @map("signature_id") @db.Uuid
  isActive               Boolean                   @default(true) @map("is_active")
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  systems                MntSystem[]
  responsibles           MntTechnicalResponsible[]
  actRequirements        ActRequirement[]
  actMasterActivityNames ActMasterActivityName[]

  @@map("mnt_areas")
}

model MntSystem {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  areaId      String         @map("area_id") @db.Uuid
  name        String         @db.VarChar(100)
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  equipments  MntEquipment[]
  area        MntArea        @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId])
  @@map("mnt_systems")
}

model MntEquipment {
  id                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String                    @db.VarChar(150)
  brand             String?                   @db.VarChar(100)
  model             String?                   @db.VarChar(100)
  partNumber        String?                   @map("part_number") @db.VarChar(100)
  serialNumber      String?                   @map("serial_number") @db.VarChar(100)
  areaId            String                    @map("area_id") @db.Uuid
  systemId          String                    @map("system_id") @db.Uuid
  technicalComments String?                   @map("technical_comments")
