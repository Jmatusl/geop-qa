model MntRequest {
  id                          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folio                       Int                          @unique @default(autoincrement())
  folioPrefix                 String                       @default("RD") @map("folio_prefix") @db.VarChar(10)
  installationId              String                       @map("installation_id") @db.Uuid
  equipmentId                 String                       @map("equipment_id") @db.Uuid
  typeId                      String                       @map("type_id") @db.Uuid
  statusId                    String                       @map("status_id") @db.Uuid
  applicantId                 String?                      @map("applicant_id") @db.Uuid
  description                 String
  tercerizedReason            String?                      @map("tercerized_reason")
  isApproved                  Boolean                      @default(false) @map("is_approved")
  approvedAt                  DateTime?                    @map("approved_at") @db.Timestamptz(6)
  approvedById                String?                      @map("approved_by") @db.Uuid
  estimatedEndDate            DateTime?                    @map("estimated_end_date") @db.Date
  actualEndDate               DateTime?                    @map("actual_end_date") @db.Date
  createdById                 String                       @map("created_by") @db.Uuid
  createdAt                   DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  evidences                   MntRequestEvidence[]
  expenses                    MntRequestExpense[]
  iterations                  MntRequestIteration[]
  timeline                    MntRequestTimeline[]
  applicant                   MntApplicant?                @relation(fields: [applicantId], references: [id])
  approvedBy                  User?                        @relation("RequestApprovedBy", fields: [approvedById], references: [id])
  createdBy                   User                         @relation("RequestCreatedBy", fields: [createdById], references: [id])
  equipment                   MntEquipment                 @relation(fields: [equipmentId], references: [id])
  installation                MntInstallation              @relation(fields: [installationId], references: [id])
  status                      MntRequestStatus             @relation(fields: [statusId], references: [id])
  type                        MntRequestType               @relation(fields: [typeId], references: [id])
  mntWorkRequirementRelations MntWorkRequirementRelation[]

  @@index([installationId])
  @@index([equipmentId])
  @@index([statusId])
  @@map("mnt_requests")
}

model MntRequestEvidence {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId   String     @map("request_id") @db.Uuid
  storagePath String     @map("storage_path")
  publicUrl   String     @map("public_url")
  fileSize    Int?       @map("file_size")
  mimeType    String?    @map("mime_type") @db.VarChar(50)
  capturedAt  DateTime?  @map("captured_at") @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  request     MntRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("mnt_request_evidences")
}

model MntRequestTimeline {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId    String            @map("request_id") @db.Uuid
  changedById  String            @map("changed_by") @db.Uuid
  action       String            @db.VarChar(50)
  prevStatusId String?           @map("prev_status_id") @db.Uuid
  newStatusId  String?           @map("new_status_id") @db.Uuid
  comment      String?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  changedBy    User              @relation(fields: [changedById], references: [id])
  newStatus    MntRequestStatus? @relation("NewStatus", fields: [newStatusId], references: [id])
  prevStatus   MntRequestStatus? @relation("PrevStatus", fields: [prevStatusId], references: [id])
  request      MntRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("mnt_request_timeline")
}

